inputs = {
flake-parts = {

};
nixpkgs-lib.url = "nix-community/nixpkgs.lib"
};
{ self, nixpkgs-lib, flake-parts, ... }
outputs = inputs @ {
nixpkgs-lib,
flake-parts,
...
}:

# 1. Keep your definitions flat and visible at the very top
let
  myCustomModule = { lib, ... }: { 
    _module.args.Mylib = {           
      lib = import ./flakeModule.nix { inherit lib; }; 
    };
  };
in

# 2. You "may" want to define a system type if necessary. 
## For pure nix-lib outputs, it's not required,
### and can possibly cause issues for consumers,
### as their system might end up "thinking" -
### it requires a system type, only works for certain systems, etc.

flake-parts.lib.mkFlake { inherit inputs; } {
  #systems = [ "x86_64-linux" "aarch64-darwin" ];

  # Safely Dogfood your module internally; 
##  Without polluting consumers inputs, adding recursion problems -
##  or copying your lib to the store more than once
  imports = [ 
    myCustomModule 
  ];

  # Export your module for downstream consumers
  flakeModules.default = myCustomModule;

  # Use your injected library inside perSystem safely
  perSystem = { config, pkgs, Mylib, ... }: {
  };
}
